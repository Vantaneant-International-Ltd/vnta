# VNTA: public, build-time configuration.
# Copy to `.env` for local dev. PUBLIC_ values are safe to expose (the Supabase
# key is publishable; Row-Level Security protects the data). Sensible defaults
# live in vite.config.ts, so a plain `npm run dev` works without this file.

# Supabase: VNTA shares the vendr project; VNTA data is namespaced `vnta_*`.
PUBLIC_SUPABASE_URL=https://fmmvqlqdhytcxeucdfbj.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_rpmSPCHja3L2Uy2_RrxjAA_Cz_NyHB2

# Cloudflare Turnstile site key (public, safe in the client). Spam gate on the
# careers and pricing/contact forms. The matching SECRET key is NOT here; it is set
# as a Supabase edge-function secret (TURNSTILE_SECRET_KEY) and read server-side
# only by the vnta-submit function.
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADrAgdwjUX9NIVP3
